	author = {Chatrou, L.W. and Pirie, M.D. and Erkens, Roy H.J. and Couvreur, T.L.P. and Neubig, Kurt M. and Abbott, J.R. and Mols, J.B. and Maas, J.W. and Saunders, R.M.K. and Chase, M.W.},
	month = may,
	year = {2012},
	note = {00126},
	keywords = {plastid markers, subfamilies, supermatrix, tribes},
	pages = {5--40},
	file = {Full Text PDF:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\ICUXVC8D\\Chatrou et al. - 2012 - A new subfamilial and tribal classification of the.pdf:application/pdf;Snapshot:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\QX3DXC8T\\abstract.html:text/html},
