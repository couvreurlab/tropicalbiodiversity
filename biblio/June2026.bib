	year = {2025},
	note = {\_eprint: https://nph.onlinelibrary.wiley.com/doi/pdf/10.1111/nph.70645},
	keywords = {collection management, global herbarium, methodological standards, next-generation digitization, plant functional traits, spectral reflectance},
	file = {Full Text PDF:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\PXDFVVNF\\Cavender-Bares et al. - 2025 - Next-generation specimen digitization capturing reflectance spectra from the world's herbaria for m.pdf:application/pdf;Snapshot:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\2JAQRND4\\nph.html:text/html},
