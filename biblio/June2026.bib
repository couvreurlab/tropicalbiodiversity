@article{dauby_conr:_2017,
	title = {{ConR}: {An} {R} package to assist large-scale multispecies preliminary conservation assessments using distribution data},
	volume = {7},
	issn = {2045-7758},
	shorttitle = {{ConR}},
	url = {http://onlinelibrary.wiley.com/doi/10.1002/ece3.3704/abstract},
	doi = {10.1002/ece3.3704},
	abstract = {The Red List Categories and the accompanying five criteria developed by the International Union for Conservation of Nature (IUCN) provide an authoritative and comprehensive methodology to assess the conservation status of organisms. Red List criterion B, which principally uses distribution data, is the most widely used to assess conservation status, particularly of plant species. No software package has previously been available to perform large-scale multispecies calculations of the three main criterion B parameters [extent of occurrence (EOO), area of occupancy (AOO) and an estimate of the number of locations] and provide preliminary conservation assessments using an automated batch process. We developed ConR, a dedicated R package, as a rapid and efficient tool to conduct large numbers of preliminary assessments, thereby facilitating complete Red List assessment. ConR (1) calculates key geographic range parameters (AOO and EOO) and estimates the number of locations sensu IUCN needed for an assessment under criterion B; (2) uses this information in a batch process to generate preliminary assessments of multiple species; (3) summarize the parameters and preliminary assessments in a spreadsheet; and (4) provides a visualization of the results by generating maps suitable for the submission of full assessments to the IUCN Red List. ConR can be used for any living organism for which reliable georeferenced distribution data are available. As distributional data for taxa become increasingly available via large open access datasets, ConR provides a novel, timely tool to guide and accelerate the work of the conservation and taxonomic communities by enabling practitioners to conduct preliminary assessments simultaneously for hundreds or even thousands of species in an efficient and time-saving way.},
	language = {en},
	number = {24},
	urldate = {2018-01-07},
	journal = {Ecology and Evolution},
	author = {Dauby, Gilles and Stévart, Tariq and Droissart, Vincent and Cosiaux, Ariane and Deblauwe, Vincent and Simo-Droissart, Murielle and Sosef, Marc S. M. and Lowry, Porter P. and Schatz, George E. and Gereau, Roy E. and Couvreur, Thomas L. P.},
	month = dec,
	year = {2017},
	keywords = {area of occupancy, criterion B, distribution range, extent of occurrence, IUCN, location, preliminary status, threatened taxa},
	pages = {11292--11303},
	file = {Texte intégral:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\C4Q89ZR4\\Dauby et al. - 2017 - ConR An R package to assist large-scale multispec.pdf:application/pdf},
}

@article{droissart_beyond_2018,
	title = {Beyond trees: {Biogeographical} regionalization of tropical {Africa}},
	volume = {45},
	issn = {1365-2699},
	shorttitle = {Beyond trees},
	url = {http://onlinelibrary.wiley.com/doi/10.1111/jbi.13190/abstract},
	doi = {10.1111/jbi.13190},
	abstract = {Aim

To delineate bioregions in tropical Africa and determine whether different plant growth forms (trees, terrestrial herbs, lianas and shrubs) display the same pattern of regionalization, diversity and endemism as the whole flora.


Location

Tropical Africa (excl. Madagascar), from 20° N to 25° S.


Taxon

Vascular plants.


Methods

Analyses were based on occurrences of 24,719 vascular plant species distributed across tropical Africa extracted from the RAINBIO database. The majority of species (93\%) were classified into four growth forms: terrestrial herbs, trees, shrubs and lianas. Biogeographical regions (bioregions) were delimited using a bipartite network clustering approach on the whole dataset and then separately for each growth form. Relationships among bioregions were investigated using non-metric multidimensional scaling ordination, flora nestedness and endemism patterns.


Results

Analyses of the whole dataset identified 16 bioregions and 11 transition zones. These were congruent with most of the currently recognized phytogeographical classifications, and also highlighted previously under-recognized bioregions. Bioregion endemism rates were lower and species richness higher when compared to estimates from the White/Association pour l'Etude Taxonomique de la Flore d'Afrique Tropicale (AETFAT) classification. Analysed separately, plant growth forms showed contrasting geographical patterns. Bioregionalization was better resolved for closed forest types using trees and lianas and for open vegetation types using terrestrial herbs, while shrubs showed good discriminative power in all vegetation types.


Main conclusions

We show that distribution patterns based on solely trees are not sufficient to define floristic bioregions in tropical Africa. Analyses of spatial patterns using different growth forms are complementary, likely reflecting different evolutionary processes and ecological relationships. The contribution of growth forms to delimit geographical floristic patterns across tropical Africa is of critical importance for land use planning and management, and for selecting priority conservation areas.},
	language = {en},
	number = {5},
	urldate = {2018-03-02},
	journal = {Journal of Biogeography},
	author = {Droissart, Vincent and Dauby, Gilles and Hardy, Olivier J. and Deblauwe, Vincent and Harris, David J. and Janssens, Steven and Mackinder, Barbara A. and Blach-Overgaard, Anne and Sonké, Bonaventure and Sosef, Marc S. M. and Stévart, Tariq and Svenning, Jens-Christian and Wieringa, Jan J. and Couvreur, Thomas L. P.},
	year = {2018},
	keywords = {African bioregions, diversity, endemism, growth forms, nestedness, network clustering, phytogeography, RAINBIO database},
	pages = {1153--1167},
	file = {Full Text PDF:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\8XDMJ5Q6\\Droissart et al. - Beyond trees Biogeographical regionalization of t.pdf:application/pdf;Snapshot:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\DDJGML53\\abstract.html:text/html},
}

