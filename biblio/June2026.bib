@article{marshall_new_2016,
	title = {A new species in the tree genus {Polyceratocarpus} ({Annonaceae}) from the {Udzungwa} {Mountains} of {Tanzania}},
	volume = {63},
	copyright = {2020Andrew R. Marshall, Thomas L.P. Couvreur, Abigail L. Summers, Nicolas J. Deere, W.R. Quentin Luke, Henry J. Ndangalasi, Sue Sparrow, David M. Johnson},
	issn = {1314-2003},
	url = {https://phytokeys.pensoft.net/article/6262/},
	doi = {10.3897/phytokeys.63.6262},
	abstract = {Polyceratocarpus askhambryan-iringae, an endemic tree species of Annonaceae from the Udzungwa Mountains of Tanzania, is described and illustrated. The new species is identified as a member of the genus Polyceratocarpus by the combination of staminate and bisexual flowers, axillary inflorescences, subequal outer and inner petals, and multi-seeded monocarps with pitted seeds. From P. scheffleri, with which it has previously been confused, it differs in the longer pedicels, smaller and thinner petals, shorter bracts, and by generally smaller, less curved monocarps that have a clear stipe and usually have fewer seeds. Because P. askhambryan-iringae has a restricted extent of occurrence, area of occupancy, and ongoing degradation of its forest habitat, we recommend classification of it as Endangered (EN) on the IUCN Red List.},
	language = {en},
	urldate = {2020-06-02},
	journal = {PhytoKeys},
	publisher = {Pensoft Publishers},
	author = {Marshall, Andrew R. and Couvreur, Thomas L. P. and Summers, Abigail L. and Deere, Nicolas J. and Luke, W. R. Quentin and Ndangalasi, Henry J. and Sparrow, Sue and Johnson, David M.},
	month = jun,
	year = {2016},
	pages = {63--76},
	file = {Full Text PDF:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\UKZYNZCE\\Marshall et al. - 2016 - A new species in the tree genus Polyceratocarpus (.pdf:application/pdf},
}

@article{bree_diversification_2020,
	title = {Diversification of {African} {Rainforest} {Restricted} {Clades}: {Piptostigmateae} and {Annickieae} ({Annonaceae})},
	volume = {12},
	copyright = {http://creativecommons.org/licenses/by/3.0/},
	shorttitle = {Diversification of {African} {Rainforest} {Restricted} {Clades}},
	url = {https://www.mdpi.com/1424-2818/12/6/227},
	doi = {10.3390/d12060227},
	abstract = {African rainforests (ARFs) are species rich and occur in two main rainforest blocks: West/Central and East Africa. This diversity is suggested to be the result of recent diversification, high extinction rates and multiple vicariance events between west/central and East African forests. We reconstructed the diversification history of two subtribes (Annickieae and Piptostigmateae) from the ecologically dominant and diverse tropical rainforest plant family Annonaceae. Both tribes contain endemic taxa in the rainforests of West/Central and East Africa. Using a dated molecular phylogeny based on 32 nuclear markers, we estimated the timing of the origin of East African species. We then undertook several diversification analyses focusing on Piptostigmateae to infer variation in speciation and extinction rates, and test the impact of extinction events. Speciation in both tribes dated to the Pliocene and Pleistocene. In particular, Piptostigma (13 species) diversified mainly during the Pleistocene, representing one of the few examples of Pleistocene speciation in an African tree genus. Our results also provide evidence of an ARF fragmentation at the mid-Miocene linked to climatic changes across the region. Overall, our results suggest that continental-wide forest fragmentation during the Neogene (23.03\&ndash;2.58 Myr), and potentially during the Pliocene, led to one or possibly two vicariance events within the ARF clade Piptostigmateae, in line with other studies. Among those tested, the best fitting diversification model was the one with an exponential speciation rate and no extinction. We did not detect any evidence of mass extinction events. This study gives weight to the idea that the ARF might not have been so negatively impacted by extinction during the Neogene, and that speciation mainly took place during the Pliocene and Pleistocene.},
	language = {en},
	number = {6},
	urldate = {2020-06-12},
	journal = {Diversity},
	publisher = {Multidisciplinary Digital Publishing Institute},
	author = {Brée, Baptiste and Helmstetter, Andrew J. and Bethune, Kévin and Ghogue, Jean-Paul and Sonké, Bonaventure and Couvreur, Thomas L. P.},
	month = jun,
	year = {2020},
	note = {Number: 6},
	keywords = {biogeographic vicariance, extinction, gene capture, gene shopping, molecular dating, phylogenomics},
	pages = {227},
	file = {diversity-12-00227-s001.pdf:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\CYUMHIVX\\diversity-12-00227-s001.pdf:application/pdf;Full Text PDF:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\FJNDM2CI\\Brée et al. - 2020 - Diversification of African Rainforest Restricted C.pdf:application/pdf;Snapshot:C\:\\Users\\couvreur\\Documents\\Zotero\\storage\\DWAKRE5B\\227.html:text/html},
}

@article{helmstetter_phylogenomic_2020,
	title = {Phylogenomic approaches reveal how climate shapes patterns of genetic diversity in an {African} rain forest tree species},
	volume = {29},
	copyright = {© 2020 John Wiley \& Sons Ltd},
	issn = {1365-294X},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/mec.15572},
	doi = {10.1111/mec.15572},
	abstract = {The world's second largest expanse of tropical rainforest is in Central Africa, and it harbours enormous species diversity. Population genetic studies have consistently revealed significant structure across Central African rainforest plants. In particular, previous studies have repeatedly demonstrated a north–south genetic discontinuity around the equatorial line, in a continuous expanse of rainforest where a climatic inversion is documented. Here, we took a phylogeographic approach by sequencing 351 nuclear markers in 112 individuals across the distribution of the African rainforest tree species Annickia affinis (Annonaceae). We showed for the first time that the north–south divide is the result of a single, major colonization event across the climatic inversion from an ancestral population located in Gabon. We suggested that differences in ecological niche of populations located on either side of this inversion may have contributed to this phylogenetic discontinuity. We found evidence for inland dispersal, predominantly in northern areas, and variable demographic histories among genetic clusters, indicating that populations responded differently to past climate change. We show how newly developed genomic tools can provide invaluable insights into our understanding of tropical rainforest evolutionary dynamics.},
	language = {en},
	number = {18},
	urldate = {2020-09-22},
	journal = {Molecular Ecology},
	author = {Helmstetter, Andrew J. and Amoussou, Biowa E. N. and Bethune, Kevin and Kamdem, Narcisse G. and Kakaï, Romain Glèlè and Sonké, Bonaventure and Couvreur, Thomas L. P.},
	year = {2020},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/mec.15572},
	keywords = {Annonaceae, climatic inversion, immigrant inviability, nuclear baiting kit, phylogeography, refugia},
	pages = {3560--3573},
